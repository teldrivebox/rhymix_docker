:{$MY_PORT} {
    # 1. root 설정 (라이믹스 설치 경로)
    root * /var/www/html

    # 2. 업로드 용량 설정 (Nginx의 client_max_body_size 32m 대응)
    request_body {
        max_size 32MB
    }

    # 3. PHP-FPM 연동 (Nginx의 fastcgi_pass 127.0.0.1:9000 대응)
    php_fastcgi localhost:9000

    # 4. 파일 서버 활성화 (index.php 자동 인식 포함)
    file_server

    # 5. 라이믹스 전용 Rewrite 규칙 (Nginx의 include snippets/rhymix.conf 대응)
    # 파일이나 폴더가 없을 때만 index.php로 넘기는 '가장 깔끔한' 방식입니다.
    handle {
        try_files {path} {path}/ /index.php?{query}
    }

    # 6. 보안 설정: 정말 민감한 파일만 접근 차단
    @forbidden {
        # 설정 파일은 절대 외부에서 보이면 안 됩니다.
        path /files/config/*
        path /config/*.php
        # 그 외 .env 나 .git 같은 숨김 파일 차단
        path /.*
    }
    # /files/cache/* 는 JS/CSS 로딩을 위해 열어두어야 하므로 위 목록에서 제외했습니다.
    error @forbidden 403
}